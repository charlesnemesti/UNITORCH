# Chain — switch VITE_CHAIN_ID to match your deployment
VITE_CHAIN_ID=1
VITE_RPC_URL=https://ethereum.publicnode.com
VITE_EXPLORER_URL=https://etherscan.io

# UniTorch ERC-20 (deflationary burn token + Uniswap v4 hook)
VITE_UNITORCH=0x82da588a1DcD34aaF726E8833364b21d37C2f70C

# Optional Uniswap pool override
VITE_UNISWAP_POOL=0x0000000000000000000000000000000000000000

# Set to true to load live on-chain burn metrics, gallery, and wallet balances
VITE_LIVE_DATA=false

# Torch NFT registry + hook fee distributor (wire when deployed)
VITE_TORCH_NFT=0x0000000000000000000000000000000000000000
VITE_REWARD_DISTRIBUTOR=0x0000000000000000000000000000000000000000
